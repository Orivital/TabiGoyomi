# 環境変数テンプレート
# 環境ごとの設定方法は README.md の「環境構成」セクションを参照してください

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Places API（任意: 未設定時は手動入力にフォールバック）
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# DB 同期スクリプト用（db:sync / db:sync-staging で使用）
# SUPABASE_PROD_DB_PASSWORD=your-prod-db-password
# SUPABASE_STAGING_DB_PASSWORD=your-staging-db-password

# 開発時のみ: デバッグログ送信先 URL（未設定なら送信しない）
# VITE_DEBUG_INGEST_URL=http://127.0.0.1:7248/ingest/...

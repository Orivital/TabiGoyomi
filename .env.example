# 環境変数テンプレート
# 環境ごとの設定方法は README.md の「環境構成」セクションを参照してください

VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# ローカル開発では `supabase status -o env` の `PUBLISHABLE_KEY` を優先してください。
# `devbox run supabase:start` または `./scripts/sync-local-supabase-env.sh` で同期できます。

# Google Places API（任意: 未設定時は手動入力にフォールバック）
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# DB 同期スクリプト用（db:sync / db:sync-staging で使用）
# SUPABASE_PROD_DB_PASSWORD=your-prod-db-password
# SUPABASE_STAGING_DB_PASSWORD=your-staging-db-password
# 通常は不要: ダンプ元・Staging 書き込み先の上書き（既定は scripts/sync-db-targets.json）
# SUPABASE_PROD_PROJECT_REF=ssyeychimkqjhzvwucap
# SUPABASE_PROD_POOLER_HOST=aws-1-ap-northeast-2.pooler.supabase.com
# SUPABASE_STAGING_PROJECT_REF=fowxrnfttrnvogssaqef
# SUPABASE_STAGING_POOLER_HOST=aws-0-ap-northeast-1.pooler.supabase.com

# 開発時のみ: デバッグログ送信先 URL（未設定なら送信しない）
# VITE_DEBUG_INGEST_URL=http://127.0.0.1:7248/ingest/...

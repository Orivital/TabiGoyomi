{
  "packages": ["nodejs@20", "pnpm@9"],
  "env": {
    "DEVBOX_COREPACK_ENABLED": "true",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },
  "shell": {
    "init_hook": "corepack enable && corepack prepare pnpm@9.15.3 --activate",
    "scripts": {
      "dev": "pnpm dev",
      "build": "pnpm build",
      "install": "pnpm install",
      "lint": "pnpm lint",
      "lint:fix": "pnpm exec eslint . --fix",
      "test": "pnpm test",
      "test:run": "pnpm test:run"
    }
  }
}
